{
  "name": "ai-manager",
  "version": "1.0.0",
  "description": "AI检测和管理系统 - 自动检测电脑上所有AI组件并进行管理",
  "main": "electron/main.js",
  "scripts": {
    "start": "node src/index.js",
    "electron": "electron .",
    "scan": "node src/scanner.js",
    "serve": "node src/server.js",
    "build": "electron-builder --win",
    "build:dir": "electron-builder --win --dir"
  },
  "dependencies": {
    "chokidar": "^3.5.3",
    "express": "^4.18.2",
    "node-os-utils": "^1.3.7",
    "open": "^10.0.3",
    "socket.io": "^4.7.2",
    "systeminformation": "^5.21.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "electron": "^32.2.7",
    "electron-builder": "^25.1.8",
    "nodemon": "^3.0.1"
  },
  "build": {
    "appId": "com.aimanager.app",
    "productName": "AI管理系统",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "src/**/*",
      "public/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "AI管理系统"
    }
  }
}
